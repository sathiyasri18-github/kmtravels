@page "/project-inquiry"
@page "/membership"
@rendermode InteractiveServer
@using SnlEngineering.Web.Models
@inject ApiService Api

<SeoHead Title="Project Enquiry"
         Description="Submit a project enquiry to SNL Engineering. Tell us about your power, sugar, ethanol or process industry engineering requirements and our team will respond promptly."
         Keywords="project enquiry, engineering inquiry, EPCM project request, SNL Engineering contact"
         CanonicalPath="/project-inquiry" />

<div class="page-header">
    <div class="container">
        <h1>Project Enquiry</h1>
        <p>Tell us about your engineering project requirements</p>
    </div>
</div>

<section class="section">
    <div class="container">
        @if (_submitted)
        {
            <div class="alert alert-success">
                <h3>Enquiry Submitted!</h3>
                <p>Thank you for your interest in SNL Engineering. Our team will review your enquiry and respond shortly.</p>
            </div>
        }
        else
        {
            <EditForm Model="_form" OnValidSubmit="Submit" class="form-card">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="form-grid">
                    <div class="form-group">
                        <label>Contact Name *</label>
                        <InputText @bind-Value="_form.FullName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <InputText @bind-Value="_form.Email" class="form-control" type="email" />
                    </div>
                    <div class="form-group">
                        <label>Phone *</label>
                        <InputText @bind-Value="_form.Phone" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Company / Organization</label>
                        <InputText @bind-Value="_form.CompanyName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>City</label>
                        <InputText @bind-Value="_form.District" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>State / Country</label>
                        <InputText @bind-Value="_form.State" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Project Type</label>
                        <InputText @bind-Value="_form.LicenseNumber" class="form-control" placeholder="e.g. Power, Sugar, Ethanol, CBG" />
                    </div>
                    <div class="form-group full-width">
                        <label>Project Details</label>
                        <InputTextArea @bind-Value="_form.Address" class="form-control" rows="4" placeholder="Describe your project scope and requirements" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @(_submitting ? "Submitting..." : "Submit Enquiry")
                </button>
            </EditForm>
        }
    </div>
</section>

@code {
    private MemberFormModel _form = new();
    private bool _submitted, _submitting;

    private async Task Submit()
    {
        _submitting = true;
        var request = new SubmitMemberRequest(MemberType.Operator, _form.FullName, _form.Email, _form.Phone,
            _form.Address, _form.District, _form.State, _form.CompanyName, _form.LicenseNumber, null);
        _submitted = await Api.PostAsync("api/public/project-inquiries", request);
        _submitting = false;
    }
}
